---
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
---

<Layout title="TuRuta — Case Study | Luis Ticona">
  <Header />

  <section class="pt-28 pb-8">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Back -->
      <a href="/#proyectos" class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-text-main transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
        </svg>
        Volver a proyectos
      </a>

      <!-- Header -->
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="tag">Transporte</span>
        <span class="text-xs text-text-dim">Perú · 2022</span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl font-bold text-text-main mb-4">TuRuta</h1>
      <p class="text-lg text-text-muted max-w-2xl mb-4">
        App mobile para encontrar la mejor ruta de transporte público en Lima. Case study completo con research, prototipado y diseño de alta fidelidad.
      </p>

      <div class="flex flex-wrap gap-2 mb-10">
        <span class="text-xs px-2 py-1 rounded-md bg-surface text-text-dim border border-border">Figma</span>
        <span class="text-xs px-2 py-1 rounded-md bg-surface text-text-dim border border-border">Mobile App</span>
        <span class="text-xs px-2 py-1 rounded-md bg-surface text-text-dim border border-border">UX Research</span>
        <span class="text-xs px-2 py-1 rounded-md bg-surface text-text-dim border border-border">Prototipado</span>
      </div>
    </div>
  </section>

  <!-- PDF Embed -->
  <section class="pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="glass-card overflow-hidden rounded-2xl">
        <div class="bg-surface/50 px-6 py-3 flex items-center justify-between border-b border-border">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span class="text-sm font-medium text-text-main">Case Study — TuRuta</span>
          </div>
          <a
            href="/projects/turuta-casestudy.pdf"
            target="_blank"
            rel="noopener"
            class="text-xs text-primary hover:text-primary-hover transition-colors flex items-center gap-1"
          >
            Abrir PDF completo
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
        <iframe
          src="/projects/turuta-casestudy.pdf"
          class="w-full border-0"
          style="height: 85vh;"
          title="TuRuta Case Study PDF"
        ></iframe>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
