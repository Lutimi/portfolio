---
interface Props {
  title: string
  description: string
  image: string
  tags: string[]
  href: string
  industry: string
  country: string
  year: string
}

const { title, description, image, tags, href, industry, country, year } = Astro.props
const isExternal = href.startsWith('http')
const isBehance = href.includes('behance.net')
---

<a
  href={href}
  target={isExternal ? '_blank' : '_self'}
  rel={isExternal ? 'noopener' : undefined}
  class="glass-card group block overflow-hidden"
>
  <!-- Image -->
  <div class="relative overflow-hidden aspect-video">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-background/80 via-transparent to-transparent"></div>

    <!-- Floating badge -->
    <div class="absolute top-4 right-4 flex gap-2">
      {isBehance && (
        <span class="inline-flex items-center gap-1 px-2 py-1 text-[10px] font-semibold uppercase tracking-wider rounded-full bg-blue-500/15 text-blue-400 border border-blue-500/25">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M22 7h-7v-2h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14h-8.027c.13 3.211 3.483 3.312 4.588 2.029h3.168zm-7.686-4h5.025c-.07-1.577-1.002-2.19-2.453-2.19-1.524 0-2.371.756-2.572 2.19zM9 15.5c0 1.5-1.5 2-2.5 2h-5.5v-13h5c2.5 0 3.5 1.5 3.5 3 0 1.5-1 2.5-1.5 2.5 1 .5 1 2 1 3v2.5zm-5.5-5h2.5c1 0 1.5-.5 1.5-1.5s-.5-1.5-1.5-1.5h-2.5v3zm0 5h3c1 0 1.5-.5 1.5-1.5s-.5-1.5-1.5-1.5h-3v3z"/></svg>
          Behance
        </span>
      )}
      <span class="tag">{industry}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-xs text-text-dim">{country}</span>
      <span class="text-text-dim">·</span>
      <span class="text-xs text-text-dim">{year}</span>
    </div>

    <h3 class="font-display text-xl font-semibold text-text-main group-hover:text-primary transition-colors mb-2">
      {title}
    </h3>

    <p class="text-sm text-text-muted leading-relaxed mb-4">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2">
      {tags.map(tag => (
        <span class="text-xs px-2 py-1 rounded-md bg-surface text-text-dim border border-border">
          {tag}
        </span>
      ))}
    </div>

    <!-- Arrow -->
    <div class="mt-4 flex items-center gap-2 text-sm font-medium text-primary opacity-0 group-hover:opacity-100 transition-opacity">
      {isBehance ? 'Ver en Behance' : 'Ver proyecto'}
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={isExternal ? "M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" : "M17 8l4 4m0 0l-4 4m4-4H3"} />
      </svg>
    </div>
  </div>
</a>
