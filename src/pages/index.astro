---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ProjectCard from '../components/ProjectCard.astro'
import ExperienceItem from '../components/ExperienceItem.astro'

const projects = [
  {
    title: 'NexVault eWallet',
    description: 'Landing page para billetera digital de nueva generación. Diseño futurista con glassmorphism, animaciones fluidas y experiencia inmersiva.',
    image: '/projects/ewallet-web/public/images/hero.png',
    tags: ['Tailwind CSS', 'Vanilla JS', 'Glassmorphism', 'Dark UI'],
    href: '/projects/ewallet-web/src/index.html',
    industry: 'Fintech',
    country: 'Perú',
    year: '2026',
  },
  {
    title: 'Web DiveRent',
    description: 'Diseño web para DiveRent, plataforma de alquiler de vehículos del grupo Divemotor. Experiencia de usuario enfocada en conversión y claridad visual.',
    image: '/images/diverent-cover.svg',
    tags: ['Figma', 'Web Design', 'UI/UX', 'Automotive'],
    href: 'https://www.behance.net/gallery/215757979/Web-DiveRent',
    industry: 'Automotive',
    country: 'Perú',
    year: '2024',
  },
  {
    title: 'Plataforma WIKIVI',
    description: 'Plataforma web de banco de videos culturales. Diseño modular con Atomic Design en Figma, permitiendo a creadores audiovisuales ofertar su contenido.',
    image: '/images/wikivi-cover.svg',
    tags: ['Figma', 'Atomic Design', 'UX Research', 'Plataforma Digital'],
    href: 'https://www.behance.net/gallery/160250757/Plataforma-WIKIVI',
    industry: 'Cultura & Media',
    country: 'Perú',
    year: '2022',
  },
  {
    title: 'TuRuta',
    description: 'App mobile para encontrar la mejor ruta de transporte público en Lima. Case study completo con research, prototipado y diseño de alta fidelidad.',
    image: '/images/turuta-cover.png',
    tags: ['Figma', 'Mobile App', 'UX Research', 'Prototipado'],
    href: '/proyecto/turuta',
    industry: 'Transporte',
    country: 'Perú',
    year: '2022',
  },
]

const skills = [
  { category: 'Diseño', items: ['Figma (Experto)', 'Design Systems', 'UX Research', 'Prototipado', 'Responsive Design'] },
  { category: 'Desarrollo', items: ['HTML/CSS', 'Tailwind CSS', 'JavaScript', 'Astro', 'SQL'] },
  { category: 'Metodologías', items: ['Scrum', 'Kanban', 'Design Thinking', 'Atomic Design'] },
  { category: 'Herramientas', items: ['Git/GitHub', 'Storybook', 'Power BI', 'Adobe XD'] },
]

const experience = [
  {
    role: 'Product Designer Senior',
    company: '10Pearls — Cliente Izipay',
    location: 'Lima, Perú',
    period: 'Ene 2025 – Actual',
    current: true,
    highlights: [
      'Lideré la creación del Design System desde cero, definiendo componentes y lineamientos para equipos de diseño y desarrollo.',
      'Diseñé experiencias para plataformas web, mobile y back-office, participando en flujos funcionales y arquitectura de información.',
      'Colaboré en la mejora de interfaces para dispositivos POS, optimizando flujos de pago.',
    ],
  },
  {
    role: 'Software Engineer for AI Training Data',
    company: 'Outlier',
    location: 'Remoto',
    period: 'Feb 2025 – Actual',
    current: true,
    highlights: [
      'Evaluación de respuestas en tareas de programación (web, UI, backend) y revisión de código.',
      'Validación de flujos conversacionales y análisis de entornos como Docker.',
    ],
  },
  {
    role: 'Diseñador UX/UI Semi Senior',
    company: 'Vide Solutions — Cliente Divemotor',
    location: 'Lima, Perú',
    period: 'Feb 2024 – Ene 2025',
    current: false,
    highlights: [
      'Showroom QR: Lideré la digitalización de experiencia en showrooms mediante códigos QR.',
      'Diseñé webs y landings para Mercedes-Benz, Jeep, Fiat, Ram, Yutong y DiveRent.',
      'Divepay: Diseñé plataforma de pagos online para gestión de pagos pendientes.',
    ],
  },
  {
    role: 'Analista UX',
    company: 'Altimea — Cliente DiveMotor',
    location: 'Lima, Perú',
    period: 'Ago 2023 – Feb 2024',
    current: false,
    highlights: [
      'Pruebas QA de páginas web para mejorar la experiencia de usuarios.',
      'Estandarización del brandbook y diseño de prototipo "Tracking Interno".',
    ],
  },
  {
    role: 'Team Leader UX/UI',
    company: 'Vide Solutions',
    location: 'Lima, Perú',
    period: 'Oct 2021 – Jul 2023',
    current: false,
    highlights: [
      'Proyecto ZoomLion: Rediseño de interfaz web en sector minero.',
      'Proyecto WIKIVI: Lideré construcción de design system modular con Atomic Design en Figma.',
      'Dirigí equipo de diseño, capacitando en UX/UI avanzado y gestionando con Kanban.',
    ],
  },
]
---

<Layout title="Luis Ticona — Portfolio">
  <Header />

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center pt-24 pb-16">
    <!-- Background effects -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/4 -left-32 w-96 h-96 bg-primary/8 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-1/4 -right-32 w-80 h-80 bg-accent/6 rounded-full blur-[100px]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/3 rounded-full blur-[200px]"></div>
    </div>

    <div class="relative mx-auto max-w-7xl px-6 w-full">
      <div class="max-w-3xl">
        <div class="animate-fade-up">
          <span class="section-label mb-6 block">
            <span class="w-2 h-2 rounded-full bg-accent inline-block animate-pulse"></span>
            Disponible para proyectos
          </span>
        </div>

        <h1 class="animate-fade-up-delay-1 font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.05] tracking-tight">
          Diseño productos<br/>
          digitales que<br/>
          <span class="text-gradient">importan</span>
        </h1>

        <p class="animate-fade-up-delay-2 mt-6 text-lg sm:text-xl text-text-muted leading-relaxed max-w-xl">
          Product Designer Senior con background en Ingeniería de Software. Especializado en experiencias end-to-end — desde discovery hasta handoff.
        </p>

        <div class="animate-fade-up-delay-3 mt-10 flex flex-wrap gap-4">
          <a href="#proyectos" class="btn-primary">
            Ver proyectos
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </a>
          <a href="https://www.behance.net/luisticona1" target="_blank" rel="noopener" class="btn-ghost">
            Behance
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Quick stats -->
        <div class="animate-fade-up-delay-3 mt-16 flex gap-12">
          <div>
            <p class="font-display text-3xl font-bold text-text-main">+4</p>
            <p class="text-sm text-text-muted mt-1">Años de experiencia</p>
          </div>
          <div>
            <p class="font-display text-3xl font-bold text-text-main">+10</p>
            <p class="text-sm text-text-muted mt-1">Proyectos entregados</p>
          </div>
          <div>
            <p class="font-display text-3xl font-bold text-text-main">UPC</p>
            <p class="text-sm text-text-muted mt-1">Ing. de Software</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROJECTS ===== -->
  <section id="proyectos" class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mb-16">
        <span class="section-label mb-4 block">Portafolio</span>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-text-main">
          Proyectos destacados
        </h2>
        <p class="mt-4 text-text-muted max-w-lg">
          Cada proyecto es una oportunidad para resolver problemas reales con diseño y tecnología.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map(project => (
          <ProjectCard {...project} />
        ))}

        <!-- Placeholder -->
        <a href="/desafios" class="glass-card flex items-center justify-center min-h-[320px] border-dashed border-border group">
          <div class="text-center px-6">
            <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-surface flex items-center justify-center group-hover:bg-primary/10 transition-colors">
              <svg class="w-6 h-6 text-text-dim group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <p class="text-sm text-text-dim font-medium group-hover:text-text-main transition-colors">Zona de Desafíos</p>
            <p class="text-xs text-text-dim mt-1">Acceso con clave</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="sobre-mi" class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Photo + Intro -->
      <div class="grid lg:grid-cols-[auto_1fr] gap-12 lg:gap-16 items-center mb-20">
        <!-- Photo -->
        <div class="relative mx-auto lg:mx-0 group">
          <div class="absolute -inset-4 bg-gradient-to-br from-primary/20 via-accent/10 to-primary/5 rounded-3xl blur-2xl opacity-60 group-hover:opacity-80 transition-opacity duration-700"></div>
          <div class="relative w-56 h-56 sm:w-64 sm:h-64 rounded-2xl overflow-hidden border-2 border-border group-hover:border-primary/30 transition-all duration-500">
            <img
              src="/images/luis-ticona.png"
              alt="Luis Misael Ticona Miranda"
              class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-background/40 via-transparent to-transparent"></div>
          </div>
          <div class="absolute -bottom-3 -right-3 w-8 h-8 rounded-lg bg-accent flex items-center justify-center shadow-lg shadow-accent/30">
            <span class="text-background text-xs font-bold">PE</span>
          </div>
        </div>

        <!-- Bio text -->
        <div>
          <span class="section-label mb-4 block">Sobre mí</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-text-main mb-6">
            Diseño + Ingeniería
          </h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              Soy Luis Misael Ticona Miranda, Product Designer Senior con formación en Ingeniería de Software por la Universidad Peruana de Ciencias Aplicadas (UPC).
            </p>
            <p>
              Me especializo en diseñar y entregar productos digitales end-to-end: desde el discovery e ideación hasta el prototipado, validación y handoff. He liderado la creación de Design Systems desde cero y diseñado experiencias para web, mobile y back-office.
            </p>
            <p>
              Trabajo de cerca con producto e ingeniería para asegurar soluciones claras, viables y escalables. Mi background técnico me permite hablar el mismo idioma que los desarrolladores y entregar diseños que se implementan sin fricción.
            </p>
          </div>

          <div class="mt-8 flex gap-4">
            <a href="https://www.behance.net/luisticona1" target="_blank" rel="noopener" class="btn-ghost text-sm">
              Ver Behance
            </a>
            <a href="https://github.com/Lutimi" target="_blank" rel="noopener" class="btn-ghost text-sm">
              Ver GitHub
            </a>
          </div>
        </div>
      </div>

      <!-- Skills grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {skills.map(group => (
          <div class="glass-card p-5">
            <h4 class="font-display font-semibold text-sm text-primary mb-3">{group.category}</h4>
            <ul class="space-y-1.5">
              {group.items.map(item => (
                <li class="text-sm text-text-muted flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-accent shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== EXPERIENCE ===== -->
  <section id="experiencia" class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="grid lg:grid-cols-[1fr_2fr] gap-16">
        <!-- Left: Heading -->
        <div class="lg:sticky lg:top-32 lg:self-start">
          <span class="section-label mb-4 block">Trayectoria</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-text-main mb-4">
            Experiencia profesional
          </h2>
          <p class="text-text-muted leading-relaxed">
            +4 años diseñando productos digitales para empresas en Perú, Panamá y Argentina.
          </p>

          <div class="mt-8 glass-card p-5">
            <h4 class="font-display font-semibold text-sm text-text-main mb-2">Formación</h4>
            <p class="text-sm text-primary font-medium">Bachiller en Ingeniería de Software</p>
            <p class="text-xs text-text-muted mt-1">Universidad Peruana de Ciencias Aplicadas</p>
            <p class="text-xs text-text-dim">2017 – 2022</p>

            <div class="mt-4 pt-4 border-t border-border">
              <p class="text-sm text-primary font-medium">UX/UI Avanzado</p>
              <p class="text-xs text-text-muted mt-1">CoderHouse, Argentina</p>
              <p class="text-xs text-text-dim">2022 – 2023</p>
            </div>
          </div>
        </div>

        <!-- Right: Timeline -->
        <div>
          {experience.map(exp => (
            <ExperienceItem {...exp} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="glass-card p-12 sm:p-16 text-center relative overflow-hidden">
        <div class="absolute inset-0 pointer-events-none">
          <div class="absolute top-0 left-1/4 w-64 h-64 bg-primary/10 rounded-full blur-[80px]"></div>
          <div class="absolute bottom-0 right-1/4 w-48 h-48 bg-accent/8 rounded-full blur-[60px]"></div>
        </div>

        <div class="relative">
          <span class="section-label mb-4 block justify-center">Colaboremos</span>
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-text-main mb-4">
            ¿Tienes un proyecto en mente?
          </h2>
          <p class="text-text-muted max-w-md mx-auto mb-8">
            Estoy disponible para proyectos freelance, consultoría de diseño y colaboraciones técnicas.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="mailto:lutimi19@gmail.com" class="btn-primary">
              Enviar email
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </a>
            <a href="https://www.behance.net/luisticona1" target="_blank" rel="noopener" class="btn-ghost">
              Ver Behance
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
